# Supabase — project URL and keys from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Custom "pptx-proposal-deck" skill id for the high-fidelity branded PPTX export
# (template selected). Get it by running `npx tsx scripts/register-pptx-skill.ts`
# once. Optional — without it the export still uses the built-in pptx skill.
# Requires org beta access to code-execution + skills + files.
ANTHROPIC_PPTX_SKILL_ID=
# Optional model override for the deck build (defaults to claude-sonnet-5).
# Set this to fall back to the Opus tier if deck fidelity regresses.
# PPTX_SKILL_MODEL=claude-opus-4-8

# Deepgram — https://console.deepgram.com (free $200 credit)
DEEPGRAM_API_KEY=

# Recall.ai — https://recall.ai dashboard
# Pin RECALL_AI_REGION to the SAME region as your Recall dashboard/API key.
# Recall regions are fully isolated (separate dashboards + keys); if this is
# unset the app auto-probes regions and a bot may land in a region you're not
# watching. Must match the region the RECALL_AI_API_KEY belongs to.
RECALL_AI_API_KEY=
RECALL_AI_REGION=us-west-2

# Public URL of this deployment. Must match the production URL exactly —
# Recall.ai webhooks are built from this value at bot-creation time.
# Production custom domain: https://app.propmaker.co (landing page is propmaker.co).
NEXT_PUBLIC_APP_URL=https://app.propmaker.co

# Stripe — https://dashboard.stripe.com/apikeys (credits & subscriptions).
# Create 8 prices: 4 RECURRING (monthly plans) + 4 ONE-TIME (packs) at the same
# $17 / $67 / $107 / $197 price points. A recurring price id can NOT be reused
# for a one-time checkout — each pack needs its own one-time price.
# Then add a webhook endpoint at {NEXT_PUBLIC_APP_URL}/api/webhooks/stripe
# listening to: checkout.session.completed, invoice.paid,
# customer.subscription.updated, customer.subscription.deleted
# Support form (/support) — https://resend.com/api-keys
# SUPPORT_EMAIL defaults to jp@mappli.co. SUPPORT_FROM_EMAIL defaults to
# Resend's shared onboarding@resend.dev, which can only deliver to the address
# that owns the Resend account — verify a domain to send from your own.
RESEND_API_KEY=
SUPPORT_EMAIL=
SUPPORT_FROM_EMAIL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring (monthly): 200 / 800 / 1,300 / 2,440 credits granted every cycle
STRIPE_PRICE_PLAN_STARTER=
STRIPE_PRICE_PLAN_PRO=
STRIPE_PRICE_PLAN_BUSINESS=
STRIPE_PRICE_PLAN_AGENCY=
# One-time: same prices, same credits, granted once
STRIPE_PRICE_PACK_STARTER=
STRIPE_PRICE_PACK_PRO=
STRIPE_PRICE_PACK_BUSINESS=
STRIPE_PRICE_PACK_AGENCY=

# Supabase — project URL and keys from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Custom "pptx-proposal-deck" skill id for the high-fidelity branded PPTX export
# (template selected). Get it by running `npx tsx scripts/register-pptx-skill.ts`
# once. Optional — without it the export still uses the built-in pptx skill.
# Requires org beta access to code-execution + skills + files.
ANTHROPIC_PPTX_SKILL_ID=
# Optional model override for the deck build (defaults to claude-sonnet-5).
# Set this to fall back to the Opus tier if deck fidelity regresses.
# PPTX_SKILL_MODEL=claude-opus-4-8

# Deepgram — https://console.deepgram.com (free $200 credit)
DEEPGRAM_API_KEY=

# Recall.ai — https://recall.ai dashboard
RECALL_AI_API_KEY=
RECALL_AI_REGION=us-west-2

# Public URL of this deployment. Must match the Vercel URL exactly —
# Recall.ai webhooks are built from this value at bot-creation time.
NEXT_PUBLIC_APP_URL=

# Stripe — https://dashboard.stripe.com/apikeys (credits & subscriptions).
# Create 4 recurring prices (plans) + 1 one-time price (top-up pack) and add a
# webhook endpoint at {NEXT_PUBLIC_APP_URL}/api/webhooks/stripe listening to:
# checkout.session.completed, invoice.paid,
# customer.subscription.updated, customer.subscription.deleted
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAN_STARTER=
STRIPE_PRICE_PLAN_PRO=
STRIPE_PRICE_PLAN_BUSINESS=
STRIPE_PRICE_PLAN_AGENCY=
STRIPE_PRICE_PACK_100=
